# Required. Alibaba Cloud Model Studio / DashScope API key.
# Used by Qwen text generation, Paraformer speech-to-text, and TTS.
# Fill this with your own key from https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# Required unless you intentionally switch providers.
# Qwen text model configuration.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-flash

# Required for browser voice input.
# This MVP records local audio and sends it directly to FastAPI, so use the realtime model.
ASR_PROVIDER=dashscope
ASR_MODEL=paraformer-realtime-8k-v2

# Required for voice output.
# Current default uses the cloned voice ID below. If you want the public preset voice instead,
# set TTS_PROVIDER=dashscope, TTS_MODEL=sambert-zhida-v1, and TTS_VOICE=sambert-zhida-v1.
TTS_PROVIDER=dashscope_cloned
TTS_MODEL=cosyvoice-v3.5-plus
TTS_VOICE_ID=cosyvoice-v3.5-plus-bailian-35c990345ebc42658d82d432b4613f2e

# Optional. Only needed when creating a new cloned voice with scripts/create_dashscope_voice.py.
# Upload your 10-30s clean voice sample to a public URL first.
# VOICE_CLONE_AUDIO_URL=https://your-public-audio-url.wav
# VOICE_CLONE_PREFIX=myvoice

# Optional. Change only if you move or rename SKILL.md.
ZHANG_SKILL_PATH=SKILL.md
